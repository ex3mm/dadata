{
    "name": "ex3mm/dadata",
    "description": "DaData.ru API client for Laravel 12+ and standalone PHP 8.5+",
    "type": "library",
    "version": "2.0.0",
    "license": "MIT",
    "keywords": ["dadata", "laravel", "address", "validation", "suggestions", "api-client"],
    "authors": [
        {
            "name": "ex3mm",
            "email": "maxim.tursin@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "guzzlehttp/guzzle": "^7.9",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "rector/rector": "^2.0",
        "orchestra/testbench": "^10.0",
        "mockery/mockery": "^1.6",
        "illuminate/support": "^12.0",
        "illuminate/contracts": "^12.0",
        "giorgiosironi/eris": "^1.0",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel integration"
    },
    "autoload": {
        "psr-4": {
            "Ex3mm\\Dadata\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ex3mm\\Dadata\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ex3mm\\Dadata\\Laravel\\DadataServiceProvider"
            ],
            "aliases": {
                "Dadata": "Ex3mm\\Dadata\\Laravel\\Facades\\Dadata"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "test:coverage": "phpunit --coverage-html coverage",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse",
        "rector": "rector process --dry-run",
        "rector:fix": "rector process"
    }
}
